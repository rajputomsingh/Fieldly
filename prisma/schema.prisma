generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(cuid())
  clerkUserId            String                  @unique
  email                  String                  @unique
  name                   String
  imageUrl               String?
  role                   UserRole?
  isOnboarded            Boolean                 @default(false)
  onboardingStep         Int                     @default(0)
  phone                  String?
  state                  String?
  district               String?
  bio                    String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  adminActions           AdminAction[]
  adminConfigUpdates     AdminConfig[]           @relation("AdminConfigUpdatedBy")
  adminSessions          AdminSession[]
  applications           Application[]
  auditLogs              AuditLog[]
  bids                   Bid[]
  assignedDisputes       Dispute[]               @relation("AssignedDisputes")
  filedDisputes          Dispute[]               @relation("DisputeFiledBy")
  disputeResolutions     DisputeResolution[]
  documents              Document[]
  farmerProfile          FarmerProfile?
  listingsOwned          LandListing[]
  landownerProfile       LandownerProfile?
  leasesAsFarmer         Lease[]                 @relation("FarmerLeases")
  leasesAsOwner          Lease[]                 @relation("OwnerLeases")
  marketSubscriptions    MarketSubscription[]
  messagesReceived       Message[]               @relation("MessagesReceived")
  messagesSent           Message[]               @relation("MessagesSent")
  notifications          Notification[]
  payments               Payment[]
  platformSettings       PlatformSetting[]
  generatedReports       Report[]
  reviewsReceived        Review[]                @relation("Reviewee")
  reviewsGiven           Review[]                @relation("Reviewer")
  savedListings          SavedListing[]
  scheduledNotifications ScheduledNotification[]
  securityEvents         SecurityEvent[]
  subscription           Subscription?

  @@index([clerkUserId])
  @@index([email])
  @@index([role])
}

model AdminConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  category    String   @default("GENERAL")
  isEncrypted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?
  admin       User?    @relation("AdminConfigUpdatedBy", fields: [updatedBy], references: [id])

  @@index([key])
  @@index([category])
}

model AdminSession {
  id         String    @id @default(cuid())
  adminId    String
  token      String    @unique
  ipAddress  String
  userAgent  String?
  location   String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastActive DateTime  @default(now())
  isRevoked  Boolean   @default(false)
  revokedAt  DateTime?
  revokedBy  String?
  admin      User      @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([token])
  @@index([expiresAt])
  @@index([isRevoked])
}

model AdminAction {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String
  entityId  String?
  changes   Json?
  metadata  Json?
  ipAddress String
  userAgent String?
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  category    String
  description String?
  isPublic    Boolean  @default(false)
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admin       User?    @relation(fields: [updatedBy], references: [id])

  @@index([key])
  @@index([category])
}

model Report {
  id          String    @id @default(cuid())
  type        String
  title       String
  description String?
  filters     Json?
  data        Json
  format      String    @default("JSON")
  fileUrl     String?
  generatedBy String
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  admin       User      @relation(fields: [generatedBy], references: [id])

  @@index([type])
  @@index([generatedBy])
  @@index([createdAt])
}

model Dispute {
  id          String              @id @default(cuid())
  type        String
  entityId    String
  filedById   String
  filedByRole UserRole
  reason      String
  description String?
  status      DisputeStatus       @default(PENDING)
  priority    DisputePriority     @default(MEDIUM)
  assignedTo  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  resolvedAt  DateTime?
  resolution  String?
  assigned    User?               @relation("AssignedDisputes", fields: [assignedTo], references: [id])
  filedBy     User                @relation("DisputeFiledBy", fields: [filedById], references: [id])
  resolutions DisputeResolution[]

  @@index([filedById])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([createdAt])
}

model DisputeResolution {
  id        String   @id @default(cuid())
  disputeId String
  adminId   String
  action    String
  notes     String
  metadata  Json?
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id])
  dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([adminId])
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique
  endpoint  String
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([resetAt])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  type      String
  severity  String
  userId    String?
  ipAddress String
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([type])
  @@index([severity])
  @@index([ipAddress])
  @@index([createdAt])
}

model FarmerProfile {
  id                String      @id @default(cuid())
  userId            String      @unique
  primaryCrops      String[]
  farmingExperience Int
  farmingType       FarmingType
  requiredLandSize  Float
  leaseDuration     Int
  irrigationNeeded  Boolean     @default(false)
  equipmentAccess   Boolean     @default(false)
  isVerified        Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LandownerProfile {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  ownershipType             String?
  verificationLevel         Int      @default(0)
  preferredPaymentFrequency String?
  preferredContactMethod    String?
  isVerified                Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  lands                     Land[]
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Land {
  id                               String            @id @default(cuid())
  landownerId                      String
  title                            String
  size                             Float
  landType                         LandType
  soilType                         String?
  latitude                         Float?
  longitude                        Float?
  village                          String?
  irrigationAvailable              Boolean           @default(false)
  electricityAvailable             Boolean?          @default(false)
  roadAccess                       Boolean?          @default(false)
  fencingAvailable                 Boolean?          @default(false)
  storageAvailable                 Boolean?          @default(false)
  allowedCropTypes                 String[]
  allowsInfrastructureModification Boolean           @default(false)
  allowsOrganicFarming             Boolean           @default(true)
  allowsSubleasing                 Boolean           @default(false)
  depositAmount                    Float?
  expectedRentMin                  Float?
  expectedRentMax                  Float?
  minLeaseDuration                 Int
  maxLeaseDuration                 Int
  createdAt                        DateTime          @default(now())
  updatedAt                        DateTime          @updatedAt
  address                          String?
  description                      String?
  district                         String?
  isActive                         Boolean           @default(true)
  pincode                          String?
  preferredPaymentFrequency        PaymentFrequency?
  previousCrops                    String[]
  saves                            Int               @default(0)
  soilReportAvailable              Boolean           @default(false)
  state                            String?
  views                            Int               @default(0)
  waterSource                      String?
  editCount                        Int               @default(0)
  isArchived                       Boolean           @default(false)
  lastEditedAt                     DateTime?
  applications                     Application[]
  documents                        Document[]
  landowner                        LandownerProfile  @relation(fields: [landownerId], references: [id], onDelete: Cascade)
  listings                         LandListing[]
  leases                           Lease[]
  images                           ListingImage[]
  soilReports                      SoilReport[]

  @@index([landownerId])
  @@index([landType])
  @@index([isActive])
  @@index([isArchived])
  @@index([createdAt])
  @@index([district, state])
}

model LandListing {
  id                   String            @id @default(cuid())
  landId               String
  ownerId              String
  title                String
  description          String?
  listingType          ListingType       @default(OPEN_BIDDING)
  status               ListingStatus     @default(DRAFT)
  basePrice            Float
  reservePrice         Float?
  buyNowPrice          Float?
  minimumLeaseDuration Int
  maximumLeaseDuration Int
  startDate            DateTime
  endDate              DateTime
  totalBids            Int               @default(0)
  highestBid           Float?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  applicationCount     Int               @default(0)
  publishedAt          DateTime?
  viewCount            Int               @default(0)
  auctionStatus        AuctionStatus     @default(UPCOMING)
  autoExtendMinutes    Int?              @default(5)
  bidIncrement         Float?            @default(1000)
  currentLeaderId      String?
  engagementScore      Float?
  hotnessScore         Float?
  lastBidAt            DateTime?
  marketScore          Float?
  riskLevel            RiskLevel         @default(LOW)
  winningBidId         String?           @unique
  applications         Application[]
  auctionEvents        AuctionEvent[]
  bids                 Bid[]
  land                 Land              @relation(fields: [landId], references: [id], onDelete: Cascade)
  owner                User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  winningBid           Bid?              @relation("WinningBid", fields: [winningBidId], references: [id])
  leases               Lease[]
  analytics            ListingAnalytics?
  images               ListingImage[]
  terms                ListingTerms?
  savedBy              SavedListing[]

  @@index([ownerId])
  @@index([status])
  @@index([listingType])
  @@index([startDate, endDate])
  @@index([createdAt])
  @@index([auctionStatus, endDate])
  @@index([hotnessScore])
}

model ListingTerms {
  id                      String           @id @default(cuid())
  listingId               String           @unique
  securityDepositRequired Boolean          @default(true)
  depositAmount           Float?
  paymentFrequency        PaymentFrequency
  additionalTerms         String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  inspectionRequired      Boolean          @default(false)
  insuranceRequired       Boolean          @default(false)
  listing                 LandListing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingImage {
  id        String       @id @default(cuid())
  listingId String?
  url       String
  caption   String?
  isPrimary Boolean      @default(false)
  createdAt DateTime     @default(now())
  sortOrder Int          @default(0)
  landId    String?
  land      Land?        @relation(fields: [landId], references: [id], onDelete: Cascade)
  listing   LandListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([landId])
  @@index([isPrimary])
}

model Bid {
  id        String         @id @default(cuid())
  listingId String
  farmerId  String
  amount    Float
  status    BidStatus      @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  message   String?
  isAutoBid Boolean        @default(false)
  isWinning Boolean        @default(false)
  outbidAt  DateTime?
  sequence  Int
  events    AuctionEvent[]
  farmer    User           @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  listing   LandListing    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  winningOf LandListing?   @relation("WinningBid")

  @@index([listingId])
  @@index([farmerId])
  @@index([status])
  @@index([listingId, amount(sort: Desc)])
  @@index([listingId, createdAt])
}

model AuctionEvent {
  id        String      @id @default(cuid())
  listingId String
  type      String
  actorId   String?
  bidId     String?
  metadata  Json?
  createdAt DateTime    @default(now())
  bid       Bid?        @relation(fields: [bidId], references: [id])
  listing   LandListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([createdAt])
}

model Application {
  id           String            @id @default(cuid())
  landId       String
  farmerId     String
  listingId    String?
  proposedRent Float?
  duration     Int
  cropPlan     String?
  message      String?
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  reviewNotes  String?
  reviewedAt   DateTime?
  farmer       User              @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  land         Land              @relation(fields: [landId], references: [id], onDelete: Cascade)
  listing      LandListing?      @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([landId, farmerId, status])
  @@index([farmerId])
  @@index([landId])
  @@index([status])
  @@index([createdAt])
}

model Lease {
  id                 String       @id @default(cuid())
  landId             String
  farmerId           String
  ownerId            String
  listingId          String?
  rent               Float
  securityDeposit    Float?
  startDate          DateTime
  endDate            DateTime
  status             LeaseStatus  @default(DRAFT)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  signedAt           DateTime?
  signedByFarmer     Boolean      @default(false)
  signedByOwner      Boolean      @default(false)
  terminationDate    DateTime?
  terminationReason  String?
  creditApproved     Boolean      @default(false)
  escrowStatus       String?
  grossContractValue Float?
  leaseSource        LeaseSource  @default(AUCTION)
  netOwnerReceivable Float?
  platformFee        Float?
  riskScore          Float?
  farmer             User         @relation("FarmerLeases", fields: [farmerId], references: [id], onDelete: Cascade)
  land               Land         @relation(fields: [landId], references: [id], onDelete: Cascade)
  listing            LandListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  owner              User         @relation("OwnerLeases", fields: [ownerId], references: [id], onDelete: Cascade)
  payments           Payment[]
  review             Review?

  @@index([farmerId])
  @@index([ownerId])
  @@index([landId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([riskScore])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  leaseId           String?
  amount            Float
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  providerRef       String?
  createdAt         DateTime      @default(now())
  dueDate           DateTime?
  notes             String?
  paidAt            DateTime?
  receiptUrl        String?
  gatewayFee        Float?
  netAmount         Float?
  paymentType       String?
  platformFee       Float?
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?
  razorpaySignature String?
  lease             Lease?        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leaseId])
  @@index([status])
  @@index([dueDate])
  @@index([razorpayOrderId])
  @@index([razorpayPaymentId])
}

model Review {
  id         String   @id @default(cuid())
  leaseId    String   @unique
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  response   String?
  lease      Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  reviewee   User     @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([revieweeId])
  @@index([rating])
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime  @default(now())
  isRead     Boolean   @default(false)
  readAt     DateTime?
  receiver   User      @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User      @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
  @@index([createdAt])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  message    String
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())
  actionUrl  String?
  readAt     DateTime?
  entityId   String?
  entityType String?
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model ScheduledNotification {
  id          String    @id @default(cuid())
  title       String
  message     String
  priority    String    @default("MEDIUM")
  targetType  String
  targetRole  String?
  targetIds   String[]  @default([])
  actionUrl   String?
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("PENDING")
  adminId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  admin       User      @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([adminId])
}

model SavedListing {
  id        String      @id @default(cuid())
  listingId String
  userId    String
  createdAt DateTime    @default(now())
  listing   LandListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
  @@index([userId])
  @@index([createdAt])
}

model ListingAnalytics {
  listingId       String      @id
  demandScore     Float?
  bidVelocity     Float?
  conversionScore Float?
  avgBidGap       Float?
  watchers        Int         @default(0)
  lastActivityAt  DateTime?
  listing         LandListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model MarketSubscription {
  id        String   @id @default(cuid())
  userId    String
  filters   Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String             @unique
  plan        String
  status      SubscriptionStatus @default(ACTIVE)
  startedAt   DateTime           @default(now())
  endsAt      DateTime?
  autoRenew   Boolean            @default(true)
  lastBilling DateTime?
  nextBilling DateTime?
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SoilReport {
  id        String    @id @default(cuid())
  landId    String
  ph        Float?
  moisture  Float?
  nutrients String?
  createdAt DateTime  @default(now())
  reportUrl String?
  testedAt  DateTime?
  testedBy  String?
  land      Land      @relation(fields: [landId], references: [id], onDelete: Cascade)

  @@index([landId])
  @@index([testedAt])
}

model Document {
  id        String   @id @default(cuid())
  userId    String?
  landId    String?
  name      String
  url       String
  createdAt DateTime @default(now())
  size      Int?
  type      String?
  land      Land?    @relation(fields: [landId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([landId])
  @@index([type])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  entity    String?
  entityId  String?
  ipAddress String?
  userAgent String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum UserRole {
  FARMER
  LANDOWNER
  ADMIN
  SUPER_ADMIN
}

enum FarmingType {
  SUBSISTENCE
  COMMERCIAL
  ORGANIC
  MIXED
  HYDROPONIC
  AQUAPONIC
}

enum LandType {
  AGRICULTURAL
  FALLOW
  ORCHARD
  PASTURE
  VINEYARD
  GREENHOUSE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
  UNDER_REVIEW
  EXPIRED
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  COMPLETED
  TERMINATED
  PENDING_SIGNATURE
  RENEWED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PROCESSING
  PARTIALLY_REFUNDED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
  TRIAL
}

enum NotificationType {
  SYSTEM
  LEASE
  PAYMENT
  MESSAGE
  LISTING
  BID
  REVIEW
  APPLICATION
  REMINDER
}

enum ListingStatus {
  DRAFT
  ACTIVE
  CLOSED
  CANCELLED
  EXPIRED
  PENDING_APPROVAL
  RENEWED
}

enum ListingType {
  OPEN_BIDDING
  FIXED_PRICE
  NEGOTIABLE
}

enum BidStatus {
  ACTIVE
  OUTBID
  WITHDRAWN
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PaymentFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  ONE_TIME
  CUSTOM
}

enum AuctionStatus {
  UPCOMING
  LIVE
  PAUSED
  CLOSED
  SETTLED
  FAILED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum LeaseSource {
  AUCTION
  DIRECT
  NEGOTIATION
}

enum DisputeStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  ESCALATED
  DISMISSED
}

enum DisputePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
